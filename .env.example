APP_NAME="EduSphere"
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:YOUR_KEY_HERE_AFTER_GENERATION
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Application Maintenance
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Authentication
BCRYPT_ROUNDS=12
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edusphere
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Broadcasting
BROADCAST_CONNECTION=log
BROADCAST_DRIVER=log

# Storage & File System
FILESYSTEM_DISK=local
DISK_LOCAL_ROOT="/storage/app"

# Queue Configuration
QUEUE_CONNECTION=database
# For production, use:
# QUEUE_CONNECTION=redis

# Cache Configuration
CACHE_STORE=database
# For production, use:
# CACHE_STORE=redis
CACHE_PREFIX=edusphere_

# Session
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,*.edusphere.local

# Memcached
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# Redis Configuration (for production)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Asset URL
VITE_APP_NAME="${APP_NAME}"
VITE_MODE=development

# ===== LIVEWIRE 3 CONFIGURATION =====
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DIRECTORY=livewire-uploads
LIVEWIRE_ASSET_URL=/app

# ===== MULTI-TENANT CONFIGURATION =====
TENANT_IDENTIFICATION_METHOD=subdomain
TENANT_DOMAIN_PREFIX=subdomain
TENANT_DATABASE_PREFIX=edusphere_
TENANT_CACHE_TTL=3600
TENANT_MIGRATIONS_PATH=database/migrations/tenant

# ===== HORIZON & QUEUE CONFIGURATION =====
HORIZON_BALANCE=simple
HORIZON_MAX_PROCESSES=10
HORIZON_MEMORY_LIMIT=512
HORIZON_TIMEOUT=60

# ===== FILE STORAGE & BACKUP =====
BACKUP_DISK=local
BACKUP_NOTIFICATION_EMAIL=admin@edusphere.com
BACKUP_NOTIFICATION_ON_FAILURE=true
BACKUP_CLEAN_OLDER_THAN_DAYS=30

# ===== JWT & PASSPORT CONFIGURATION =====
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=

# ===== LARAVEL OCTANE (Optional - for high performance) =====
OCTANE_SERVER=swoole
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=2
OCTANE_MAX_REQUESTS=500
OCTANE_WATCH=true

# ===== SPATIE PERMISSIONS =====
PERMISSION_CACHE_EXPIRATION_TIME=86400
ROLE_CACHE_EXPIRATION_TIME=86400

# ===== ACTIVITY LOG =====
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOG_CLEAN_OLDER_THAN_DAYS=90

# ===== SCHOOL-SPECIFIC SETTINGS =====
SCHOOL_DEFAULT_SUBSCRIPTION_DAYS=365
SCHOOL_MAX_STUDENTS=1000
SCHOOL_MAX_TEACHERS=100
SCHOOL_CURRENCY=USD
SCHOOL_TIMEZONE=UTC

# ===== PAYMENT GATEWAY CONFIGURATION =====
PAYMENT_GATEWAY=stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Alternative gateways:
# PAYMENT_GATEWAY=razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ===== SMS GATEWAY CONFIGURATION =====
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Alternative providers:
# SMS_PROVIDER=aws
# AWS_SNS_REGION=us-east-1

# ===== FILE UPLOAD LIMITS =====
UPLOAD_MAX_SIZE=10240
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx,zip
UPLOAD_STORAGE_PATH="/storage/uploads"

# ===== RATE LIMITING =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BY_IP=true

# ===== DEVELOPMENT TOOLS =====
TELESCOPE_ENABLED=false
TELESCOPE_ONLY_AUTHORIZED=true
HORIZON_ENABLED=true
DUSK_DRIVER_CONNECTION=testing

# ===== SECURITY SETTINGS =====
APP_DEBUG_ALLOWED_IPS=127.0.0.1,::1
ENFORCE_HTTPS=false
# For production:
# ENFORCE_HTTPS=true

# ===== LOCALIZATION =====
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
AVAILABLE_LOCALES=en,es,fr,hi
# For Indian schools, uncomment:
# APP_LOCALE=hi
# APP_FALLBACK_LOCALE=en

# ===== TIMEZONE =====
# Default: UTC
# For Indian schools: Asia/Kolkata
# For US schools: America/New_York
# Other options: America/Chicago, Europe/London, Asia/Singapore, Australia/Sydney

